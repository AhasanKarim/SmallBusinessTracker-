# --- Authentication ---
# Plain password for first-time setup. The app will hash and persist on first login.
# After first run you can remove this and rely on the stored hash.
APP_PASSWORD=changeme

# Pre-hashed password (overrides APP_PASSWORD if set). Generate with: npm run hash-password -- 'your-password'
# APP_PASSWORD_HASH=

# 32+ character random string used to sign session cookies. Generate with: openssl rand -base64 48
SESSION_SECRET=please-change-me-to-a-long-random-string-min-32-chars

# --- Database ---
DATABASE_URL=file:./data/app.db

# --- File uploads ---
UPLOAD_DIR=./data/uploads

# --- Optional ---
# NODE_ENV=production

# Set to "true" ONLY when serving over HTTPS (behind Caddy / Cloudflare /
# Tailscale Funnel etc.). When true, the session cookie is marked Secure,
# which browsers refuse over plain HTTP (LAN access would break).
# COOKIE_SECURE=false
